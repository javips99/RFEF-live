# =============================================================================
# RFEF Live — Variables de entorno
# =============================================================================
# Copia este fichero como ".env" y rellena tus valores reales.
# NUNCA subas el fichero ".env" a Git (ya está en .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# API-SPORTS (OBLIGATORIA)
# -----------------------------------------------------------------------------
# Tu clave de acceso a la API de api-sports.io.
# Cómo obtenerla:
#   1. Regístrate en https://dashboard.api-football.com/
#   2. Ve a Profile > My Access
#   3. Copia la API Key que aparece en pantalla
# El plan gratuito incluye 100 llamadas/día.
API_KEY=


# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
# Puerto en el que escucha el servidor Express.
# Valor por defecto si no se define: 3000
PORT=3000

# Entorno de ejecución.
# Valores válidos: development | production
# En "production" se desactivan los stack traces en los errores.
NODE_ENV=development


# -----------------------------------------------------------------------------
# CORS (solo necesario en producción)
# -----------------------------------------------------------------------------
# Origen exacto permitido para peticiones cross-origin.
# Ejemplo en producción: https://rfef-live.tudominio.com
# En development puedes dejarlo vacío (acepta localhost por defecto).
ALLOWED_ORIGIN=
